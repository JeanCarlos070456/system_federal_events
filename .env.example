# ============================================================
# FEDERAL EVENTOS - DJANGO
# Copie este arquivo para .env e preencha os dados reais.
# Nunca suba o .env no GitHub.
# ============================================================

DJANGO_SECRET_KEY=troque-essa-chave-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
DJANGO_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Supabase PostgreSQL direto para o Django ORM.
# Use a connection string do Supabase em Project Settings > Database.
# Exemplo:
# DATABASE_URL=postgresql://postgres.xxxxx:SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=

# Supabase Auth/Storage
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=SUA_ANON_KEY
SUPABASE_STORAGE_BUCKET=federal-eventos

# Sessão
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
